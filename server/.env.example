EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
# Set to "sandbox" to use eBay's Sandbox API (instant keys, fake test data).
# Leave unset (or "production") once your production keyset is approved.
EBAY_ENV=sandbox

# Optional: AliExpress Affiliate API (cross-border results, clearly labeled in the UI).
# Leave these unset to skip AliExpress entirely - the app works fine with eBay alone.
ALIEXPRESS_APP_KEY=your-aliexpress-app-key
ALIEXPRESS_APP_SECRET=your-aliexpress-app-secret
ALIEXPRESS_TRACKING_ID=your-aliexpress-tracking-id

PORT=3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (keep secret)

# Shared secret for the Vercel Cron price-alert check (/api/cron/check-alerts).
# Set the same value in Vercel env vars; Vercel sends it as a Bearer token.
CRON_SECRET=any-long-random-string

# Optional: Resend (https://resend.com) for price-drop alert emails.
# Without a key, price drops are still recorded on the alert row, just not emailed.
# RESEND_FROM must be a sender on a domain you verified in Resend
# (onboarding@resend.dev works for testing but only delivers to your own account email).
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=CarPartsRadar <alerts@yourdomain.com>

# Optional: eBay Partner Network campaign id (https://partnernetwork.ebay.com).
# When set, live eBay listings link through commissionable affiliate URLs.
# Without it, plain item links are used and nothing else changes.
EBAY_EPN_CAMPAIGN_ID=your-epn-campaign-id

# Local development only. Set to 1 to run account features against an
# in-memory mock instead of Supabase. IGNORED in production: an unconfigured
# production deploy disables accounts (503) rather than accepting any password.
ALLOW_MOCK_AUTH=0
