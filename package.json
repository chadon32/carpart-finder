    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "headroom.js": "^0.12.0",
    "lucide-react": "^1.23.0",
    "posthog-js": "^1.396.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
